# ─────────────────────────────────────────────────────────────
# Prospect IQ — backend configuration
# Copy this file to `.env` and adjust as needed. Everything has a
# safe default, so the app runs end-to-end with ZERO keys.
# ─────────────────────────────────────────────────────────────

# LLM provider for the agentic layer.
#   template     -> deterministic, offline, NO KEY NEEDED (default; demo-safe)
#   huggingface  -> free Hugging Face Inference API
#   groq         -> free Groq API (OpenAI-compatible, very fast)
#   ollama       -> fully local models
LLM_PROVIDER=template

# Hugging Face free Inference API — token: https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Groq (optional) — key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (optional, local) — https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Synthetic data generation
NUM_CUSTOMERS=2500
RANDOM_SEED=42
DATA_DIR=data_store

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
